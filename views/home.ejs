<%- include("partials/header"); -%>

<section class="hero-card mb-5">
  <p class="eyebrow mb-2">Welcome back</p>
  <h1 class="display-6 fw-semibold mb-3">Write your story, one day at a time.</h1>
  <p class="lead mb-0"><%= startingContent %></p>
</section>

<section>
  <div class="d-flex align-items-center justify-content-between mb-3">
    <h2 class="section-title mb-0">Recent Posts</h2>
    <a href="/compose" class="btn btn-gradient">New Post</a>
  </div>

  <% if (!posts.length) { %>
    <div class="empty-state">
      <p class="mb-3">No posts yet. Start writing your first journal entry.</p>
      <a href="/compose" class="btn btn-outline-light">Create your first post</a>
    </div>
  <% } %>

  <div class="row g-4">
    <% posts.forEach(function(post){ %>
      <div class="col-12">
        <article class="post-card">
          <h3 class="mb-2"><%= post.title %></h3>
          <p class="mb-3 text-muted"><%= post.content.substring(0, 150) %>...</p>
          <a class="read-more" href="/posts/<%= post.title %>">Read full post →</a>
        </article>
      </div>
    <% }); %>
  </div>
</section>

<%- include("partials/footer"); -%>
