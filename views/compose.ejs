<%- include("partials/header"); -%>

<section class="content-card">
  <p class="eyebrow mb-2">Compose</p>
  <h1 class="mb-4">Create a new post</h1>

  <form action="/compose" method="post" class="row g-3">
    <div class="col-12">
      <label class="form-label" for="postTitle">Title</label>
      <input class="form-control form-control-lg" id="postTitle" type="text" name="postTitle" required />
    </div>
    <div class="col-12">
      <label class="form-label" for="postBody">Post</label>
      <textarea class="form-control" id="postBody" name="postbody" rows="10" required></textarea>
    </div>
    <div class="col-12">
      <button class="btn btn-gradient" type="submit">Publish Post</button>
    </div>
  </form>
</section>

<%- include("partials/footer"); -%>
